OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://www.right.codes/codex/v1
OPENAI_MODEL=gpt-5.5
NEWS_API_KEY=your-newsapi-key-here
FINNHUB_API_KEY=your-finnhub-api-key-here
MARKETAUX_API_KEY=your-marketaux-api-key-here

# Context Window Management
CONTEXT_TOKEN_THRESHOLD=600000     # When to trigger summarization (default: 600000)
CONTEXT_MESSAGE_THRESHOLD=100      # Fallback message count limit (default: 100)
CONTEXT_RECENT_MESSAGES=20         # How many recent messages to preserve (default: 20)
CONTEXT_WARNING_THRESHOLD=400000   # When to apply aggressive compression (default: 400000)
CONTEXT_MAX_ARTICLES=10            # Max articles per tool result (aggressive mode)
CONTEXT_ENABLE_COMPRESSION=true    # Master switch

# Retry/Fix Mechanism Configuration
RETRY_ENABLE=true                  # Enable retry mechanism
RETRY_THRESHOLD_OVERALL=6.0        # Trigger retry if overall score < 6.0
RETRY_THRESHOLD_ACCURACY=5.0       # Critical: accuracy must be >= 5.0
RETRY_MAX_ATTEMPTS=1               # Max retry attempts (1-3 recommended)
RETRY_STRATEGY=auto                # Strategy: auto|fix|redo|disabled
RETRY_SHOW_ATTEMPTS=true           # Show retry attempts to user

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# API Settings
API_CORS_ORIGINS=http://localhost:3000
API_REQUEST_TIMEOUT_SECONDS=120
